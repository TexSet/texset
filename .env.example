# Where TexSet keeps your projects (.tex sources, compiled PDFs, the SQLite index).
# Defaults to ./projects. In Docker this is a bind mount so the files show up on
# your machine too. Use an absolute path if you want them somewhere specific.
TEXSET_DATA_DIR=./projects

# Port the app listens on. 7474 by default to stay clear of the usual suspects.
PORT=7474
