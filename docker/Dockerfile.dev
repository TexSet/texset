# Development image: same TeX Live runtime as production, but runs the Next dev
# server with hot reload. Source is bind-mounted from the host via compose, so
# edits on your machine show up instantly.

FROM node:20-bookworm-slim
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

WORKDIR /app

# build toolchain for better-sqlite3, plus xelatex and common free fonts
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ \
    texlive-full \
    fontconfig \
    fonts-liberation \
    fonts-dejavu \
    fonts-noto-core \
    fonts-noto-cjk \
    && rm -rf /var/lib/apt/lists/*

ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=7474
ENV TEXSET_DATA_DIR=/app/projects

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .

EXPOSE 7474
CMD ["pnpm", "dev"]
